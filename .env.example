# Backend service
SERVER_PORT=8080
DATABASE_URL=postgres://ascension:ascension@localhost:5432/ascension
JWT_KEY=your_jwt_secret_key_here
RUN_MIGRATION=true

# MinIO service
MINIO_ROOT_USER=ascension
MINIO_ROOT_PASSWORD=ascension
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=videos

# RabbitMQ service
RABBITMQ_DEFAULT_USER=ascension
RABBITMQ_DEFAULT_PASS=ascension
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://ascension:ascension@localhost:5672

# Database service
POSTGRES_HOST=postgresql
POSTGRES_USER=ascension
POSTGRES_PASSWORD=ascension
POSTGRES_DB=ascension
DB_URI=postgres://ascension:ascension@localhost:5432/ascension

# AI service
PYTHONUNBUFFERED=1

# Mobile service
BACKEND_URL=http://localhost:8080